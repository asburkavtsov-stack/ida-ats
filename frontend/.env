REACT_APP_API_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS = https://ida-ats.vercel.app,http://localhost:3000

# Для консольного виводу (dev):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Для реального відправлення (Gmail):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
# App Password: Google Account → Security → 2-Step → App passwords
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

DEFAULT_FROM_EMAIL=IDA ATS <your@gmail.com>

# Резервний HR якщо кандидат без assigned_to і вакансія без owner:
NOTIFICATIONS_FALLBACK_HR_EMAIL=hr@your-org.com
